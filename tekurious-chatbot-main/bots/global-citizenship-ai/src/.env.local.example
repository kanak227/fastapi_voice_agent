# Local overrides (optional)
# Copy to .env.local to override values from .env

# Choose one: gemini | openai
LLM_PROVIDER=openai

# OpenAI model override
OPENAI_MODEL=gpt-4o-mini

# Gemini model override
GEMINI_MODEL=models/gemini-2.0-flash

# Optional: enable detailed error responses for localhost requests
DEBUG_ERRORS=1

# Optional: disable uvicorn reload if you want a single stable process
UVICORN_RELOAD=0
